					["untrigger"] = {
					},
				}, -- [1]
				{
					["trigger"] = {
						["custom_hide"] = "timed",
						["type"] = "custom",
						["events"] = "Wheelup Wheeldown",
						["custom_type"] = "event",
						["subeventSuffix"] = "_CAST_START",
						["custom"] = "function(event)\n    if event == 'Wheelup' and aura_env.acted == 'true' then\n        aura_env.dev = math.max(0,aura_env.dev - 1)\n    elseif event == 'Wheeldown' and aura_env.acted == 'true' then\n        aura_env.dev = math.min(7,aura_env.dev + 1)\n    end\nend",
						["event"] = "Health",
						["subeventPrefix"] = "SPELL",
