		["醉拳 Stagger v0"] = {
			["outline"] = "OUTLINE",
			["authorOptions"] = {
				{
					["type"] = "toggle",
					["name"] = "|cFFFF0000启用此属性 - Enable This Property",
					["default"] = true,
					["key"] = "set",
					["useDesc"] = false,
					["width"] = 2,
				}, -- [1]
				{
					["text"] = "",
					["useName"] = false,
					["type"] = "header",
