						["use_percentpower"] = false,
						["customDuration"] = "function()\n    local endTime = select(6, WA_GetUnitBuff(\"player\", 215479)) or GetTime()\n    local expirationTime = endTime - GetTime()\n    local maxTime = 21\n    return expirationTime, maxTime, true\nend",
