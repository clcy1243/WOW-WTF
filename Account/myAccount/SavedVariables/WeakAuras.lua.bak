			["customText"] = "function() \n    local p    \n    if aura_env.states and aura_env.states[2].armortargetpercent then \n        local t=aura_env.states[2].armortargetpercent\n        if aura_env.config.cc then\n            p=  string.format('%.1f%%',t)       \n        else\n            p=  string.format('%.0f%%',t)       \n        end           \n    end\n    \n    \n    if p then\n        if (GetLocale() == \"zhCN\") then\n            p=aura_env.config.textc..p\n        else\n            p=aura_env.config.texto..p\n        end\n        return p\n    end\nend",
