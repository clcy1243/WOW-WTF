		["腐蚀 Corruption"] = {
			["outline"] = "OUTLINE",
			["authorOptions"] = {
				{
					["type"] = "toggle",
					["key"] = "set",
					["default"] = true,
					["name"] = "|cFFFF0000启用此属性 - Enable This Property",
