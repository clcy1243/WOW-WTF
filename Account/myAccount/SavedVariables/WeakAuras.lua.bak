g.npc133835, --狂野的群居血虱\n    [\"133870\"] = aura_env.config.npc133870, --染病鞭笞者\n    [\"134284\"] = aura_env.config.npc134284, --堕落的亡语者\n    [\"133836\"] = aura_env.config.npc133836, --复活的护卫\n    [\"138187\"] = aura_env.config.npc138187, --怪诞恐魔\n    [\"133912\"] = aura_env.config.npc133912, --血誓污染者\n    \n    --托尔达戈\n    [\"130025\"] = aura_env.config.npc130025, --铁潮暴徒\n    [\"130026\"] = aura_env.config.npc130026, --水鼠帮海语者\n    [\"135699\"] = aura_env.config.npc135699, --艾什凡狱卒\n    [\"127486\"] = aura_env.config.npc127486, --艾什凡军官\n    [\"130027\"] = aura_env.config.npc130027, --艾什凡水兵\n    [\"130655\"] = aura_env.config.npc130655, --鲍比·豪里斯\n    [\"127488\"] = aura_env.config.npc127488, --艾什凡火法师\n    [\"136665\"] = aura_env.config.npc136665, --艾什凡观察员\n    [\"130028\"] = aura_env.config.npc130028, --艾什凡炉火医师\n    \n    \n    --维克雷斯庄园\n    [\"131850\"] = aura_env.config.npc131850, --疯狂的生存专家\n    [\"134024\"] = aura_env.config.npc134024, --贪吃的蛆虫\n    [\"131677\"] = aura_env.config.npc131677, --毒心织符者\n    [\"131586\"] = aura_env.config.npc131586, --宴会招待员\n    [\"131666\"] = aura_env.config.npc131666, --女巫会塑棘者\n    [\"131858\"] = aura_env.config.npc131858, --荆棘卫士\n    [\"131685\"] = aura_env.config.npc131685, --符文信徒\n    [\"131587\"] = aura_env.config.npc131587, --着魔的队长\n    [\"131670\"] = aura_env.config.npc131670, --毒心藤蔓扭曲者\n    [\"131812\"] = aura_env.config.npc131812, --毒心诱魂者\n    [\"135474\"] = aura_env.config.npc135474, --棘刺助祭\n    [\"135365\"] = aura_env.config.npc135365, --主母阿尔玛\n    [\"131819\"] = aura_env.config.npc131819, --女巫会占卜者\n    [\"131818\"] = aura_env.config.npc131818, --显眼的女巫\n    \n    --麦卡贡行动 - 垃圾场\n    [\"150160\"] = aura_env.config.npc150160, --屑骨恶霸\n    [\"150146\"] = aura_env.config.npc150146, --屑骨萨满\n    [\"150143\"] = aura_env.config.npc150143, --屑骨碾肉者\n    [\"150276\"] = aura_env.config.npc150276, --重装拳机\n    [\"150250\"] = aura_env.config.npc150250, --械顶轰击者\n    [\"150254\"] = aura_env.config.npc150254, --废钢猎犬\n    [\"150251\"] = aura_env.config.npc150251, --械顶机械师\n    [\"150169\"] = aura_env.config.npc150169, --剧毒潜伏者\n    [\"150297\"] = aura_env.config.npc150297, --麦卡贡重整者\n    [\"150165\"] = aura_env.config.npc150165, --粘液元素\n    [\"155090\"] = aura_env.config.npc155090, --阳极处理的线圈承载者\n    \n    --麦卡贡行动 - 车间\n    [\"144294\"] = aura_env.config.npc144294, --麦卡贡工匠\n    [\"144295\"] = aura_env.config.npc144295, --麦卡贡机械师\n    [\"144298\"] = aura_env.config.npc144298, --防御机器人MkIII型\n    [\"144293\"] = aura_env.config.npc144293, --废物处理单位\n    [\"151657\"] = aura_env.config.npc151657, --炸弹？\n    [\"150254\"] = aura_env.config.npc150254, --废钢猎犬\n    \n}\n--[[enter NPCID above if you want to include it to be marked, you can find NPCID on wowhead url of said mob, example:\nhttps://www.wowhead.com/npc=128551/irontide-mastiff\n]]\n\n\n\n--DO NOT TOUCH\naura_env.marks = {}\naura_env.assigned = {}",
					["do_custom"] = true,
				},
			},
			["triggers"] = {
				{
					["trigger"] = {
						["type"] = "custom",
						["custom_type"] = "event",
						["custom_hide"] = "custom",
						["event"] = "Health",
						["unit"] = "player",
						["subeventSuffix"] = "_CAST_START",
						["spellIds"] = {
						},
						["events"] = "PLAYER_REGEN_ENABLED, PLAYER_REGEN_DISABLED, UNIT_COMBAT, UPDATE_MOUSEOVER_UNIT, CLEU:UNIT_DIED",
						["names"] = {
						},
						["check"] = "event",
						["custom"] = "function(event, ...)\n    \n    --handles premarked mobs\n    if event == \"PLAYER_REGEN_DISABLED\" or event == \"PLAYER_REGEN_ENABLED\" then\n        aura_env.marks = {}\n        aura_env.assigned = {}\n        for i = 1,40 do\n            local premarked = \"nameplate\"..i\n            if UnitExists(premarked) and GetRaidTargetIndex(premarked) and not UnitPlayerControlled(premarked) then\n                if not aura_env.mobList[UnitGUID(premarked)] then\n                    aura_env.assigned[GetRaidTargetIndex(premarked)] = true\n                    aura_env.marks[UnitGUID(premarked)] = GetRaidTargetIndex(premarked)\n                end\n            end\n            \n        end        \n        --handles premarked players\n        for unit in WA_IterateGroupMembers() do\n            if GetRaidTargetIndex(unit) then\n                aura_env.assigned[GetRaidTargetIndex(unit)] = true\n                aura_env.marks[unit] = GetRaidTargetIndex(unit)\n            end\n        end\n    end\n    \n    \n    --mouseover functionality\n    if event == \"UPDATE_MOUSEOVER_UNIT\"  and aura_env.config.mouseover then\n        guid = UnitGUID(\"mouseover\")\n        unitid =select(6,strsplit(\"-\",guid))\n        if UnitExists(\"mouseover\") and not GetRaidTargetIndex(\"mouseover\") and not aura_env.marks[\"mouseover\"] and aura_env.mobList[unitid] and not UnitIsDead(\"mouseover\") then\n            \n            \n            --handles premarked players\n            for unit in WA_IterateGroupMembers() do\n                if GetRaidTargetIndex(unit) then\n                    aura_env.assigned[GetRaidTargetIndex(unit)] = true\n                    aura_env.marks[unit] = GetRaidTargetIndex(unit)\n                end            \n            end\n            \n            for i=1,5 do\n                if not aura_env.assigned[aura_env.order[i]] then           \n                    aura_env.marks[guid] = aura_env.order[i]\n                    aura_env.assigned[aura_env.order[i]] = true\n                    SetRaidTarget(\"mouseover\", aura_env.order[i])\n                    return false\n                end\n            end\n        end\n    end\n    \n    \n    \n    --regular marking\n    if event == \"UNIT_COMBAT\" then\n        unit = select(1, ...)\n        if UnitExists(unit) and UnitAffectingCombat(unit) and UnitCanAttack(\"player\", unit) and not GetRaidTargetIndex(unit) and not aura_env.marks[UnitGUID(unit)] and aura_env.mobList[select(6, strsplit(\"-\", UnitGUID(unit)))] then\n            for i=1,5 do\n                if not aura_env.assigned[aura_env.order[i]] then\n                    aura_env.marks[UnitGUID(unit)] = aura_env.order[i]\n                    aura_env.assigned[aura_env.order[i]] = true\n                    SetRaidTarget(unit, aura_env.order[i])\n                    return false\n                end                \n            end    \n        end\n        \n    end\n    \n    \n    \n    \n    --Frees up marks when mobs die\n    if event == \"COMBAT_LOG_EVENT_UNFILTERED\" and select(2,...) == \"UNIT_DIED\" and aura_env.marks[select(8,...)] and UnitExists(unit) then\n        a = select(1, strsplit(\"-\", UnitGUID(unit)))\n        if a~=\"player\" then\n            \n            aura_env.assigned[aura_env.marks[select(8,...)]] = false\n            aura_env.marks[select(8,...)] = nil\n        end\n    end    \nend",
