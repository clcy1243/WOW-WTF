		["闪躲 Dodge v5"] = {
			["outline"] = "OUTLINE",
			["authorOptions"] = {
				{
					["type"] = "toggle",
					["key"] = "set",
					["default"] = false,
					["name"] = "|cFFFF0000启用此属性 - Enable This Property",
