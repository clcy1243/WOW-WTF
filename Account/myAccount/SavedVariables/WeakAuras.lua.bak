				["init"] = {
					["custom"] = "aura_env.order={1,3,4,6,7,5,2,8}\n--星星=1 紫菱=3 绿三角=4 蓝方块=6 红叉=7 月亮=5 大饼=2 骷髅=8\n\naura_env.mobList = {\n    [\"161510\"] = true, -- 觉醒词缀 - 触手\n    \n    --阿塔达萨\n    [\"127879\"] = aura_env.config.npc127879, --祖尔的持盾卫士\n    [\"122969\"] = aura_env.config.npc122969, --赞枢利巫医\n    [\"125977\"] = aura_env.config.npc125977, --复生图腾\n    [\"128434\"] = aura_env.config.npc128434, --飨宴的啸天龙\n    [\"122972\"] = aura_env.config.npc122972, --达萨莱占卜师\n    [\"122971\"] = aura_env.config.npc122971, --达萨莱战神\n    [\"132126\"] = aura_env.config.npc132126, --鎏金女祭司\n    [\"122984\"] = aura_env.config.npc122984, --达萨莱巨像\n    [\"122973\"] = aura_env.config.npc122973, --达萨莱神官\n    \n    --自由镇\n    [\"128551\"] = aura_env.config.npc128551, --铁潮猎犬\n    [\"129788\"] = aura_env.config.npc129788, --铁潮锯骨者\n    [\"127111\"] = aura_env.config.npc127111, --铁潮桨手\n    [\"129529\"] = aura_env.config.npc129529, --黑齿格斗家\n    [\"129547\"] = aura_env.config.npc129547, --黑齿拳手\n    [\"129600\"] = aura_env.config.npc129600, --水鼠帮盐鳞战士\n    [\"129527\"] = aura_env.config.npc129527, --水鼠帮海盗\n    [\"130012\"] = aura_env.config.npc130012, --铁潮破坏者\n    [\"126919\"] = aura_env.config.npc126919, --铁潮唤雷者\n    \n    --诸王之眠\n    [\"134174\"] = aura_env.config.npc134174, --影裔巫医\n    [\"134158\"] = aura_env.config.npc134158, --影裔勇士\n    [\"134251\"] = aura_env.config.npc134251, --总管姆巴拉\n    [\"137473\"] = aura_env.config.npc137473, --守卫队长阿图\n    [\"134331\"] = aura_env.config.npc134331, --拉胡艾大王\n    [\"135204\"] = aura_env.config.npc135204, --鬼灵妖术祭司\n    [\"135239\"] = aura_env.config.npc135239, --幽魂巫医\n    [\"135235\"] = aura_env.config.npc135235, --幽魂兽王\n    \n    --风暴神殿\n    [\"134139\"] = aura_env.config.npc134139, --神殿骑士\n    [\"134137\"] = aura_env.config.npc134137, --神殿侍从\n    [\"136186\"] = aura_env.config.npc136186, --海贤灵魂师\n    [\"139800\"] = aura_env.config.npc139800, --唤风者学徒\n    [\"139799\"] = aura_env.config.npc139799, --铁舟学徒\n    [\"136214\"] = aura_env.config.npc136214, --风语者海蒂丝\n    [\"134