				["main"] = {
					["colorR"] = 1,
					["duration"] = "0.5",
					["colorA"] = 1,
					["colorG"] = 0.996078431372549,
					["colorB"] = 0.9686274509803922,
					["duration_type"] = "seconds",
					["use_translate"] = false,
					["easeStrength"] = 3,
					["scaleType"] = "straightScale",
					["type"] = "custom",
					["use_color"] = true,
					["easeType"] = "none",
					["translateFunc"] = "function(progress, startX, startY, deltaX, deltaY)\n      local prog = (progress * 3.5) % 1\n      local bounce = math.ceil(progress * 3.5)\n      local bounceDistance = math.sin(prog * math.pi) * (bounce / 4)\n    return startX + (bounceDistance * deltaX), startY + (bounceDistance * deltaY)\n  end\n  ",
					["scaley"] = 1,
					["alpha"] = 0,
					["scaleFunc"] = "function(progress, startX, startY, scaleX, scaleY)\n      return startX + (progress * (scaleX - startX)), startY + (progress * (scaleY - startY))\n    end\n  ",
					["y"] = 0,
					["colorType"] = "custom",
					["x"] = 0,
					["translateType"] = "bounceDecay",
					["colorFunc"] = "function(progress, r1, g1, b1, a1, r2, g2, b2, a2)\n    -- print(\"Color\", r1, g1, b1, a1, r2, g2, b2, a2)\n    \n    local color = { \n        {r = 0.0, g = 1.0, b = 0.2}, --Light\n        {r = 1.0, g = 0.7, b = 0.0}, --Moderate\n        {r = 1.0, g = 0.0, b = 0.0} --Heavy\n    }\n    \n    local charges, maxCharges, start, duration, _ = GetSpellCharges(2565)\n    \n    local c = color[3]\n    \n    if (charges >= 1 and charges < 2) then\n        c = color[1];\n    elseif (charges >= 2) then\n        c = color[1]; \n    end\n    -- print(\"c\", c.r, c.g, c.b)\n    return c.r, c.g, c.b, 1\nend",
					["rotate"] = 0,
					["scalex"] = 1,
					["use_scale"] = false,
				},
				["finish"] = {
					["type"] = "none",
					["duration_type"] = "seconds",
					["easeStrength"] = 3,
					["easeType"] = "none",
				},
