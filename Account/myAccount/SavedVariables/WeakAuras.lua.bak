			},
			["displayText"] = "%c",
			["customText"] = "function()\n    local b,ca =GetManaRegen()\n    local p=''\n    \n    if aura_env.config.ba then\n        if aura_env.config.k then\n            if b >=1e3 then \n                b= string.format('%.1fk',b/1e3)            \n            else \n                b=format('%.0f', b)                \n            end        \n        else\n            b=format('%.0f', b)\n        end        \n        p='|cFF00FF00'..b..'|r'\n    end\n    \n    if aura_env.config.ca then\n        if aura_env.config.k then\n            if ca >=1e3 then \n                ca=string.format('%.1fk',ca/1e3)            \n            else\n                ca=format('%.0f', ca)                \n            end        \n        else\n            ca=format('%.0f', ca)\n        end \n        if p~='' then\n            p=p..'-'\n        end        \n        p=p..'|cFFFF0000'..ca..'|r'\n    end    \n    \n    if p~='' then        \n        if (GetLocale() == \"zhCN\") then\n            p=aura_env.config.textc..p\n        else\n            p=aura_env.config.texto..p\n        end\n        return p\n    end\nend",
