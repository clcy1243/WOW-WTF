			["desaturateBackground"] = false,
			["displayTextRight"] = "%c",
			["customTextUpdate"] = "event",
			["sparkRotationMode"] = "AUTO",
			["justify"] = "LEFT",
			["displayTextLeft"] = "%p",
			["triggers"] = {
				{
					["trigger"] = {
						["use_power"] = false,
						["genericShowOn"] = "showOnActive",
						["names"] = {
							"Staggered Daze", -- [1]
						},
						["duration"] = "1",
						["powertype"] = 3,
						["use_absorbMode"] = true,
						["subeventPrefix"] = "SPELL",
						["debuffType"] = "HARMFUL",
						["custom_type"] = "stateupdate",
						["use_powertype"] = true,
						["custom_hide"] = "custom",
						["custom"] = "function\nend",
						["type"] = "status",
						["power"] = "60",
						["subeventSuffix"] = "_CAST_START",
						["power_operator"] = ">=",
						["use_unit"] = true,
						["event"] = "Health",
						["use_percentpower"] = false,
						["customDuration"] = "function()\n    return UnitHealth(\"player\"), UnitHealthMax(\"player\"), true\nend\n\n\n\n\n\n\n\n\n\n\n\n\n",
						["unevent"] = "auto",
						["spellIds"] = {
						},
						["events"] = "UNIT_AURA",
						["check"] = "update",
						["unit"] = "player",
						["percentpower"] = "35",
						["percentpower_operator"] = ">=",
					},
					["untrigger"] = {
						["custom"] = "function(self,unitID)\n    if not (unitID == 'player') then return false end    \n    if (UnitHealth(\"player\") == 0) then\n        return true\n    end\nend",
						["unit"] = "player",
						["percentpower_operator"] = "<",
						["use_percentpower"] = true,
						["percentpower"] = "35",
						["use_unit"] = true,
					},
				}, -- [1]
				["activeTriggerMode"] = 1,
			},
			["endAngle"] = 360,
			["internalVersion"] = 29,
			["useAdjustedMin"] = false,
			["animation"] = {
				["start"] = {
					["duration_type"] = "seconds",
					["type"] = "none",
					["easeStrength"] = 3,
					["easeType"] = "none",
				},
				["main"] = {
					["scaleFunc"] = "function(progress, startX, startY, scaleX, scaleY)\n      return startX + (progress * (scaleX - startX)), startY + (progress * (scaleY - startY))\n    end\n  ",
					["duration"] = "0.5",
					["colorB"] = 1,
					["colorG"] = 0.16078431372549,
					["colorR"] = 0.137254901960784,
					["scalex"] = 1,
					["use_translate"] = false,
					["easeStrength"] = 3,
					["use_scale"] = false,
					["type"] = "custom",
					["use_color"] = true,
					["easeType"] = "none",
					["translateFunc"] = "function(progress, startX, startY, deltaX, deltaY)\n      local prog = (progress * 3.5) % 1\n      local bounce = math.ceil(progress * 3.5)\n      local bounceDistance = math.sin(prog * math.pi) * (bounce / 4)\n    return startX + (bounceDistance * deltaX), startY + (bounceDistance * deltaY)\n  end\n  ",
					["scaley"] = 1,
					["alpha"] = 0,
					["translateType"] = "bounceDecay",
					["y"] = 0,
					["x"] = 0,
					["colorType"] = "custom",
					["scaleType"] = "straightScale",
					["colorFunc"] = "function(progress, r1, g1, b1, a1, r2, g2, b2, a2)\n    --print(\"Percent\", WA_STAGGER.percent)\n    local color = { \n        {r = 0.0, g = 1.0, b = 0.2}, --Light\n        {r = 1.0, g = 0.7, b = 0.0}, --Moderate\n        {r = 1.0, g = 0.0, b = 0.0} --Heavy\n    }\n    \n    local WA_HEALTH = {}\n    WA_HEALTH.value = UnitHealth('player')\n    WA_HEALTH.max = UnitHealthMax('player')\n    WA_HEALTH.percent = WA_HEALTH.value / WA_HEALTH.max\n    \n    \n    --STAGGER_YELLOW_TRANSITION = 0.3\n    if (WA_HEALTH.percent > 0.35 and WA_HEALTH.percent < 0.7) then\n        color = color[2]; --Moderate\n    elseif (WA_HEALTH.percent > 0.7) then\n        color =color[1]; --Heavy\n    else\n        color = color[3]; --Light\n    end\n    \n    --print(\"Color\", color.r, color.g, color.b)\n    return color.r, color.g, color.b, a1\nend",
					["rotate"] = 0,
					["duration_type"] = "seconds",
					["colorA"] = 1,
				},
