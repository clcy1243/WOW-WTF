					["key"] = "texto",
					["useLength"] = false,
				}, -- [9]
			},
			["displayText"] = "%c",
			["customText"] = "function() \n    local p,c\n    local t=GetDodgeChance('player')\n    if v5 then\n        if v5 > t then \n            c=\"|cFF00FF00\"\n        elseif v5 < t then\n            c=\"|cFFFF0000\"\n        else\n            c=\"|cFFFFFFFF\"\n        end\n    end\n    if aura_env.config.cc then\n        p=  string.format('%.1f%%',t)       \n    else\n        p=  string.format('%.0f%%',t)       \n    end       \n    if aura_env.config.gai then\n        if t>v5 then\n            if p ~='' then p=p..' ' end\n            p=p..'+'..string.format('%.0f%%',t-v5)\n        elseif t<v5 then            \n            if p ~='' then p=p..' ' end\n            p=p..'-'..string.format('%.0f%%',v5-t)\n        end        \n    end\n    \n    if p then\n        if c then\n            p=c..p..'|r'\n        end\n        if aura_env.config.sys then\n            p=STAT_DODGE..p\n        else            \n            if (GetLocale() == \"zhCN\") then\n                p=aura_env.config.textc..p\n            else\n                p=aura_env.config.texto..p\n            end\n        end        \n        return p\n    end\nend\n--[[\nfunction()\n    return format('%.0f',GetDodgeChance('player'))\nend\n]]\n\n\n",
