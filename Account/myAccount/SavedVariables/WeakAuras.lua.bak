				["main"] = {
					["scaleFunc"] = "    function(progress, startX, startY, scaleX, scaleY)\n      return startX + (progress * (scaleX - startX)), startY + (progress * (scaleY - startY))\n    end\n  ",
					["scalex"] = 1,
					["use_scale"] = false,
					["colorB"] = 1,
					["alphaType"] = "straight",
					["colorA"] = 1,
					["colorG"] = 1,
					["alphaFunc"] = "    function(progress, start, delta)\n      return start + (progress * delta)\n    end\n  ",
					["rotate"] = 0,
					["colorR"] = 1,
					["use_translate"] = true,
					["use_alpha"] = true,
					["type"] = "custom",
					["scaleType"] = "straightScale",
					["use_color"] = false,
					["easeType"] = "none",
					["translateFunc"] = "function(progress, startX, startY, deltaX, deltaY)\n    local dest_frame = aura_env.state.dest_frame\n    local dest_frame_height =  aura_env.state.dest_frame_height\n    aura_env.region:ClearAllPoints()\n    aura_env.region:SetPoint(\"BOTTOM\",dest_frame,\"BOTTOM\",0,dest_frame_height*progress)\n    return startX, startY\nend",
					["preset"] = "orbit",
					["alpha"] = 0,
					["x"] = 0,
					["y"] = 0,
					["colorType"] = "straightColor",
					["scaley"] = 1,
					["translateType"] = "custom",
					["colorFunc"] = "    function(progress, r1, g1, b1, a1, r2, g2, b2, a2)\n      return r1 + (progress * (r2 - r1)), g1 + (progress * (g2 - g1)), b1 + (progress * (b2 - b1)), a1 + (progress * (a2 - a1))\n    end\n  ",
