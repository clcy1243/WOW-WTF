		["Corrupt 2"] = {
			["outline"] = "None",
			["xOffset"] = 0,
			["displayText"] = "%c",
			["customText"] = "function()\n    local firsttime = time({ year =2020, month=5, day=21, hour=7})\n    local interval = 60*60*24*7/2\n    local nowtime = math.floor((time()-firsttime) / interval)\n    local lmt = firsttime + (nowtime + 1)*interval\n    local lft = lmt - time()\n    local d = math.floor(lft/60/60/24)\n    local hr = math.floor(lft/60/60)%24\n    local mn = math.floor(lft/60)%60\n    local sc = lft%60\n    local ts = d..'日'..hr..'时'..mn..'分'..sc..'秒'\n    local tmpt = '距离下次轮换还有：'..ts\n    return tmpt\nend",
			["yOffset"] = -152,
			["anchorPoint"] = "TOP",
			["customTextUpdate"] = "update",
			["url"] = "https://wago.io/9Lkj_ajIJ/9",
