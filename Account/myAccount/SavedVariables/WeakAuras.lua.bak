			["displayText"] = "%c",
			["customText"] = "function() \n    local p\n    if aura_env.states and aura_env.states[2].blocktargetpercent then \n       local t=aura_env.states[2].blocktargetpercent        \n        if aura_env.config.cc then\n            p=  string.format('%.1f%%',t)       \n        else\n            p=  string.format('%.0f%%',t)       \n        end           \n    end\n    \n    if p then\n        if (GetLocale() == \"zhCN\") then\n            p=aura_env.config.textc..p\n        else\n            p=aura_env.config.texto..p\n        end\n        return p\n    end\nend\n\n--[[\nfunction()\n    return format('%.0f',GetBlockChance('player'))\nend\n]]",
